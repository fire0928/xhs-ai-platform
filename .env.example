# ============================================
# 红书智创 - 环境变量配置示例
# 复制此文件为 .env 后按需修改
# ============================================

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=xhs_db
DB_USER=xhs_user
DB_PASS=Xhs@2024!user

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=XhsRedis@2024

# --- MinIO ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=xhs_admin
MINIO_SECRET_KEY=XhsMinio@2024

# --- JWT ---
JWT_SECRET=XhsJwtSecretKey2024Secure256bit!!

# --- AES Encryption Key (32 chars) ---
AES_KEY=XhsAES256Key!!@2024Secure

# --- Publish Engine URL (for Spring Boot to call) ---
PUBLISH_ENGINE_URL=http://localhost:8001

# --- Server URL (for Publish Engine to callback) ---
SERVER_URL=http://localhost:8080
